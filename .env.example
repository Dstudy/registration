# ============================================================
# VMS — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Database ---
DATABASE_URL=mysql://root:rootpassword@localhost:3306/vms_db
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=vms_db

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# --- Application ---
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# --- Email (Gmail SMTP) ---
# Enable 2FA on Gmail then create an App Password at:
# https://myaccount.google.com/apppasswords
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# --- Shift Confirmation Token ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONFIRMATION_TOKEN_SECRET=change-me-confirmation-secret

# --- Security ---
BCRYPT_ROUNDS=10
